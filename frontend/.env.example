# ============================================================
# KleverTorrentHub - Frontend Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# Port the backend is listening on (must match PORT in backend/.env, default 3000)
BACKEND_PORT=3000

# Owner wallet address — must match OWNER_WALLET in backend/.env
# Used to show/hide the Admin Panel link in the UI (no sensitive data exposed)
VITE_OWNER_WALLET=klv1your_wallet_address_here

# Backend API URL (leave as /api in production when served from same origin)
VITE_API_URL=/api

# Your public frontend URL
VITE_APP_URL=http://localhost:5173

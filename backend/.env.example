# ============================================================
# KleverTorrentHub - Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Database ────────────────────────────────────────────────
# Options: "sqlite" (default, file-based) | "postgres"
DB_TYPE=sqlite

# SQLite: path to the database file (relative to backend root)
SQLITE_PATH=./data/kth.db

# PostgreSQL (only needed if DB_TYPE=postgres):
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=kth
# PG_USER=kth_user
# PG_PASSWORD=changeme

# ── Admin ───────────────────────────────────────────────────
# Klever wallet address of the tracker owner.
# This wallet gets access to the admin dashboard at /admin.
# It is just an address — not a private key. Safe to set publicly.
OWNER_WALLET=klv1your_wallet_address_here

# ── Auth / Klever ────────────────────────────────────────────
# The domain shown in the sign-in challenge message
AUTH_DOMAIN=localhost

# Klever network: "mainnet" | "testnet" | "devnet"
KLEVER_NETWORK=testnet

# ── Reward System ───────────────────────────────────────────
# Admin wallet used to send reward tokens to users.
# Set ONE of the two options below (not both):
#
#   Option A — 24-word mnemonic phrase:
# REWARD_ADMIN_MNEMONIC=word1 word2 word3 ... word24
#
#   Option B — private key as hex string:
# REWARD_ADMIN_PRIVATE_KEY=your_private_key_hex_here

# KDA token identifier of the reward token (assigned after CreateAsset TX)
# Format: TICKER-XXXXXX  e.g. "KTH-A1B2C3"
# Use "KLV" to reward with native KLV directly from the admin wallet balance
KTH_TOKEN_ID=KTH-000000

# Set to "true" if you own the KDA token and want to mint new supply on each claim.
# Leave "false" (default) to send from the admin wallet's existing balance instead.
# Note: "true" requires the admin wallet to have the Mint role on the token.
#       "true" also avoids SameAccountError when admin and user are the same wallet.
REWARD_USE_MINT=false

# Number of decimal places the token was created with.
# Must match the token's precision on Klever (check KleverScan → Assets).
# KLV = 6, most KDA tokens = 6. Set to 0 for whole-number tokens.
REWARD_TOKEN_PRECISION=6

# Reward rate per hour of seeding, in minimal units (10^precision per whole token).
# Examples:
#   precision=6 → 10_000_000 = 10 tokens/h
#   precision=0 → 10         = 10 tokens/h
REWARD_RATE_PER_HOUR=10000000

# ── Tracker ─────────────────────────────────────────────────
# How often (ms) to clean up inactive peers
PEER_CLEANUP_INTERVAL=60000

# Seconds a peer stays active without re-announcing
PEER_TTL=1800

# ── Upload ──────────────────────────────────────────────────
# Max torrent file size in bytes (default 5 MB)
MAX_TORRENT_SIZE=5242880

# Directory for uploaded .torrent files
UPLOAD_DIR=./uploads

# ── Optional Features ───────────────────────────────────────
# Set to "true" to enable the adult content category
ENABLE_ADULT_CATEGORY=false

# Set to "true" to require an invite code for new users
REQUIRE_INVITE=false
